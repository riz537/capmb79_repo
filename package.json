{
  "name": "b79capmapp",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "express": "^4",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-productsmgmt": "cds watch --open com.demo.productsmgmt/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-ordermgmt": "cds watch --open com.demo.ordermgmt/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-storeanalytics": "cds watch --open com.demo.storeanalytics/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/productsmgmt",
    "app/ordermgmt"
  ],
  "cds": {
    "requires": {
      "auth": {
        "[development]": {
          "kind": "mocked",
          "users": {
            "venkatesh": {
              "password": "venkatesh",
              "roles": [
                "Owner"
              ],
              "attr": {
                "storeName": [
                  "GACHIBOWLI",
                  "KPHP",
                  "INORBIT"
                ]
              }
            },
            "manoj": {
              "password": "manoj",
              "roles": [
                "Employee"
              ],
              "attr": {
                "storeName": [
                  "GACHIBOWLI"
                ]
              }
            }
          }
        },
        "[production]": {
          "kind": "xsuaa"
        }
      },
      "[production]": {
